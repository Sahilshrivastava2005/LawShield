# ── LLM Provider API Keys ─────────────────────────────────────────────────────
# Obtain your key from the respective provider's console.
# You only need the key for the provider you set in DEFAULT_LLM_PROVIDER.

OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...
ANTHROPIC_API_KEY=sk-ant-...

# Active LLM provider: openai | gemini | anthropic
DEFAULT_LLM_PROVIDER=gemini

# ── Infrastructure ─────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
ELASTICSEARCH_URL=http://localhost:9200

# ── Optional: Redis for persistent session history ─────────────────────────────
# Leave blank to use in-memory session history (data lost on restart).
REDIS_URL=
